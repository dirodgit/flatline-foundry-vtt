{{!-- FLATLINE | Ficha de Especialidade --}}
<form class="flatline-sheet item-sheet especialidade-sheet" autocomplete="off">
  <header class="item-sheet-header">
    <img class="item-image" src="{{item.img}}" data-edit="img" alt="{{item.name}}"/>
    <div class="item-header-fields">
      <input class="item-name" type="text" name="name" value="{{item.name}}"/>
      <span class="item-type-badge">{{localize "FLATLINE.ItemType.especialidade"}}</span>
    </div>
  </header>
  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="details">{{localize "FLATLINE.Item.Tab.Details"}}</a>
    <a class="item" data-tab="desc">{{localize "FLATLINE.Item.Tab.Desc"}}</a>
  </nav>
  <section class="sheet-body">
    <div class="tab" data-tab="details">
      <div class="form-grid">
        <div class="form-group">
          <label>{{localize "FLATLINE.Especialidade.Arquetipo"}}</label>
          <select name="system.arquetipo">
            <option value="">{{localize "FLATLINE.Especialidade.Geral"}}</option>
            {{#each archetypes}}
              <option value="{{this.value}}" {{selected this.value ../system.arquetipo}}>{{this.label}}</option>
            {{/each}}
          </select>
        </div>
        <div class="form-group">
          <label>{{localize "FLATLINE.Especialidade.Prereqs"}}</label>
          <input type="text" name="system.prereqs" value="{{system.prereqs}}"
                 placeholder="{{localize 'FLATLINE.Especialidade.PrereqsPlaceholder'}}"/>
        </div>
        <div class="form-group checkbox-group">
          <label>
            <input type="checkbox" name="system.geral" {{checked system.geral}}/>
            {{localize "FLATLINE.Especialidade.GeralCheck"}}
          </label>
        </div>
      </div>
    </div>
    <div class="tab" data-tab="desc">
      {{editor system.description target="system.description" button=true engine="prosemirror" collaborate=false}}
    </div>
  </section>
</form>
