          </li>
        {{/each}}
      </ul>
    </div>

  </div>{{!-- /attributes-skills-grid --}}

  {{!-- CONDIÇÕES --}}
  <div class="conditions-section">
    <h3 class="section-label">{{localize "FLATLINE.Conditions.Title"}}</h3>
    <div class="conditions-grid">

      {{!-- Físicas --}}
      <div class="condition-column fisica">
        <div class="condition-header">
          <span>{{localize "FLATLINE.Conditions.Fisica"}}</span>
          <span class="penalty-badge {{#if physicalPenalty}}active{{/if}}">{{#if physicalPenalty}}-{{physicalPenalty}}{{/if}}</span>
          <button class="condition-add" data-tipo="fisica" data-tooltip="{{localize 'FLATLINE.Condition.Add'}}">+</button>
        </div>
        {{#each-in conditions.fisica}}
          {{#unless (eq @key "broken")}}
          <div class="condition-row grade-{{@key}} {{#if this.active}}active{{/if}}">
            <span class="condition-grade-label">{{localize (concat "FLATLINE.Condition." @key)}}</span>
            {{#if this.active}}
              <input type="text" class="condition-label" data-tipo="fisica" data-grade="{{@key}}"
                     value="{{this.label}}" placeholder="{{localize 'FLATLINE.Condition.Describe'}}"/>
              <button class="condition-remove" data-tipo="fisica" data-tooltip="{{localize 'FLATLINE.Condition.Remove'}}">✕</button>
            {{else}}
              <span class="condition-empty">—</span>
            {{/if}}
          </div>
          {{/unless}}
        {{/each-in}}
        {{#if conditions.fisica.broken}}
          <div class="condition-row broken active">
            <span class="broken-label">⚡ {{localize "FLATLINE.Conditions.Broken"}}</span>
          </div>
        {{/if}}
      </div>

      {{!-- Mentais --}}
      <div class="condition-column mental">
        <div class="condition-header">
          <span>{{localize "FLATLINE.Conditions.Mental"}}</span>
          <span class="penalty-badge {{#if mentalPenalty}}active{{/if}}">{{#if mentalPenalty}}-{{mentalPenalty}}{{/if}}</span>
          <button class="condition-add" data-tipo="mental" data-tooltip="{{localize 'FLATLINE.Condition.Add'}}">+</button>
        </div>
        {{#each-in conditions.mental}}
          {{#unless (eq @key "broken")}}
          <div class="condition-row grade-{{@key}} {{#if this.active}}active{{/if}}">
            <span class="condition-grade-label">{{localize (concat "FLATLINE.Condition." @key)}}</span>
            {{#if this.active}}
              <input type="text" class="condition-label" data-tipo="mental" data-grade="{{@key}}"
                     value="{{this.label}}" placeholder="{{localize 'FLATLINE.Condition.Describe'}}"/>
              <button class="condition-remove" data-tipo="mental" data-tooltip="{{localize 'FLATLINE.Condition.Remove'}}">✕</button>
            {{else}}
              <span class="condition-empty">—</span>
            {{/if}}
          </div>
          {{/unless}}
        {{/each-in}}
        {{#if conditions.mental.broken}}
          <div class="condition-row broken active">
            <span class="broken-label">⚡ {{localize "FLATLINE.Conditions.Broken"}}</span>
          </div>
        {{/if}}
      </div>

    </div>{{!-- /conditions-grid --}}
  </div>

  {{!-- TRILHA DE DEGRADAÇÃO --}}
  <div class="degradation-section">
    <div class="degradation-header">
      <h3 class="section-label">{{localize "FLATLINE.Degradation.Title"}}</h3>
      <span class="degradation-die-label">{{localize "FLATLINE.Degradation.Die"}}: D{{degradationDie}}</span>
      <button class="roll-degradation" data-tooltip="{{localize 'FLATLINE.Degradation.Roll'}}">
        🎲 {{localize "FLATLINE.Degradation.RollBtn"}}
      </button>
    </div>
    <div class="degradation-trail">
      {{#each degradationTrail}}
        <div class="degradation-step {{this.level}} {{#if this.active}}active{{/if}}"
             data-index="{{this.index}}"
             data-tooltip="{{this.index}}"
             title="{{this.index}}">
          <span>{{this.index}}</span>
        </div>
      {{/each}}
    </div>
    <div class="degradation-levels-legend">
      <span class="cicatriz">1–3 Cicatrizes</span>
      <span class="falha">4–6 Falhas</span>
      <span class="colapso">7–9 Colapso</span>
      <span class="falencia">10–11 Falência</span>
      <span class="flatline">12 FLATLINE</span>
    </div>
  </div>

</div>{{!-- /stats-tab --}}
