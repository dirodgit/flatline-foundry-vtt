        <button class="roll-attribute attribute-btn" data-attribute="empatia">
          <span class="attr-label">{{localize "FLATLINE.Attribute.Empatia"}}</span>
          <span class="attr-die die-{{attributes.empatia.dieLetter}}">{{attributes.empatia.dieLetter}}</span>
        </button>
        <input class="attr-value" type="number" name="system.attributes.empatia.value"
               value="{{attributes.empatia.value}}" min="6" max="12" step="2"/>
        {{#if attributes.empatia.penalty}}
          <span class="attr-penalty">-{{attributes.empatia.penalty}}</span>
