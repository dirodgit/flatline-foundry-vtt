{{!-- FLATLINE | Aba: Atributos & Perícias --}}
<div class="stats-tab">

  {{!-- ATRIBUTOS + PERÍCIAS --}}
  <div class="attributes-skills-grid">

    {{!-- FORÇA --}}
    <div class="attribute-column" data-attribute="forca">
      <div class="attribute-header">
        <button class="roll-attribute attribute-btn" data-attribute="forca" data-tooltip="{{localize 'FLATLINE.Roll.RollAttribute'}}">
          <span class="attr-label">{{localize "FLATLINE.Attribute.Forca"}}</span>
          <span class="attr-die die-{{attributes.forca.dieLetter}}">{{attributes.forca.dieLetter}}</span>
        </button>
        <input class="attr-value" type="number" name="system.attributes.forca.value"
               value="{{attributes.forca.value}}" min="6" max="12" step="2"/>
        {{#if attributes.forca.penalty}}
          <span class="attr-penalty">-{{attributes.forca.penalty}}</span>
        {{/if}}
      </div>
      <ul class="skills-list">
        {{#each skillsByAttribute.forca}}
          <li class="skill-item" data-skill="{{this.key}}">
            <button class="roll-skill skill-roll-btn" data-skill="{{this.key}}" data-tooltip="{{localize 'FLATLINE.Roll.RollSkill'}}">
              <span class="skill-name">{{this.label}}</span>
              <span class="skill-die die-letter-{{this.dieLetter}}">{{this.dieLetter}}</span>
            </button>
            <select class="skill-value-select" name="system.skills.{{this.key}}.value">
              <option value="0"  {{selected 0  this.value}}>—</option>
              <option value="6"  {{selected 6  this.value}}>D</option>
              <option value="8"  {{selected 8  this.value}}>C</option>
              <option value="10" {{selected 10 this.value}}>B</option>
              <option value="12" {{selected 12 this.value}}>A</option>
            </select>
            <span class="skill-used skill-used-toggle {{#if this.used}}active{{/if}}" data-skill="{{this.key}}"
                  data-tooltip="{{localize 'FLATLINE.Skill.MarkUsed'}}" title="{{localize 'FLATLINE.Skill.UsedXP'}}">★</span>
          </li>
        {{/each}}
      </ul>
    </div>

    {{!-- AGILIDADE --}}
    <div class="attribute-column" data-attribute="agilidade">
      <div class="attribute-header">
        <button class="roll-attribute attribute-btn" data-attribute="agilidade" data-tooltip="{{localize 'FLATLINE.Roll.RollAttribute'}}">
          <span class="attr-label">{{localize "FLATLINE.Attribute.Agilidade"}}</span>
          <span class="attr-die die-{{attributes.agilidade.dieLetter}}">{{attributes.agilidade.dieLetter}}</span>
        </button>
        <input class="attr-value" type="number" name="system.attributes.agilidade.value"
               value="{{attributes.agilidade.value}}" min="6" max="12" step="2"/>
        {{#if attributes.agilidade.penalty}}
          <span class="attr-penalty">-{{attributes.agilidade.penalty}}</span>
        {{/if}}
      </div>
      <ul class="skills-list">
        {{#each skillsByAttribute.agilidade}}
          <li class="skill-item" data-skill="{{this.key}}">
            <button class="roll-skill skill-roll-btn" data-skill="{{this.key}}">
              <span class="skill-name">{{this.label}}</span>
              <span class="skill-die">{{this.dieLetter}}</span>
            </button>
            <select class="skill-value-select" name="system.skills.{{this.key}}.value">
              <option value="0"  {{selected 0  this.value}}>—</option>
              <option value="6"  {{selected 6  this.value}}>D</option>
              <option value="8"  {{selected 8  this.value}}>C</option>
              <option value="10" {{selected 10 this.value}}>B</option>
              <option value="12" {{selected 12 this.value}}>A</option>
            </select>
            <span class="skill-used skill-used-toggle {{#if this.used}}active{{/if}}" data-skill="{{this.key}}">★</span>
          </li>
        {{/each}}
      </ul>
    </div>

